{
  "name": "whatsapp-chatlink",
  "version": "1.0.0",
  "description": "Generate WhatsApp click-to-chat links. Zero dependencies.",
  "license": "MIT",
  "author": "wabrowse",
  "homepage": "https://wabrowse.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/wabrowse/whatsapp-link-generator"
  },
  "keywords": [
    "whatsapp",
    "wa.me",
    "chat",
    "link",
    "click-to-chat",
    "messaging"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc && node scripts/build.mjs",
    "test": "node --test test/index.test.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
